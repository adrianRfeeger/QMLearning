},{"type":"heading","depth":4,"position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"Exercise 5.2: CHSH Simulation","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"u6KcfDAPYi"}],"identifier":"exercise-5-2-chsh-simulation","label":"Exercise 5.2: CHSH Simulation","html_id":"exercise-5-2-chsh-simulation","implicit":true,"key":"kMfeZ4VDMD"},{"type":"paragraph","position":{"start":{"line":33,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"Write a function that:\na) Generates random measurement angles for Alice and Bob\nb) Simulates measurement outcomes for a Bell state\nc) Computes the CHSH quantity S","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"XXRJRvWf2S"}],"key":"UF4WZjcvKd"},{"type":"details","children":[{"type":"summary","children":[{"type":"text","value":"Click for answer","key":"gEm9s61PNL"}],"key":"aEhx6LLmT8"},{"type":"code","lang":"python","meta":null,"value":"import numpy as np\n\ndef simulate_CHSH(n_measurements=10000):\n    rng = np.random.default_rng(42)\n    # One common set of optimal angles for ideal Bell correlations\n    a, a_p = 0, np.pi/2          # Alice: 0°, 90°\n    b, b_p = np.pi/4, -np.pi/4  # Bob: 45°, -45°\n    \n    # For this idealized Bell-pair model, correlation = cos(angle_diff)\n    def E(angle_a, angle_b):\n        expected = np.cos(angle_a - angle_b)\n        p_same = (1 + expected) / 2\n        products = np.where(rng.random(n_measurements // 4) < p_same, 1, -1)\n        return np.mean(products)\n    \n    S = E(a, b) + E(a, b_p) + E(a_p, b) - E(a_p, b_p)\n    return S\n\nprint(f\"Simulated CHSH: S = {simulate_CHSH():.3f}\")\nprint(\"Should be ≈ 2.83 (quantum) vs 2.00 (classical limit)\")","key":"PDrfmqAOvZ"}],"key":"KIrPBARxJn"},{"type":"thematicBreak","position":{"start":{"line":65,"column":1},"end":{"line":65,"column":1}},"key":"Ojzoz0LcMq"},{"type":"heading","depth":4,"position":{"